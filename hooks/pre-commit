#!/usr/bin/env bash
#
# Phase 0 秘密情報ガード（Issue #4） — gitleaks pre-commit フック
#
# ステージ済みの差分を gitleaks でスキャンし、AWS アクセスキー・アカウントID
# などの秘密情報が含まれていればコミットを中断する（fail-closed）。
# この repo は public のため、誤コミットを「コミット前」に止めるのが目的。
#
# 有効化: リポジトリルートで一度だけ
#   git config core.hooksPath hooks
#
# どうしても1回だけバイパスしたい場合のみ（非推奨）:
#   git commit --no-verify
set -euo pipefail

# gitleaks を PATH → ~/.local/bin の順で探す。
if command -v gitleaks >/dev/null 2>&1; then
  GITLEAKS="$(command -v gitleaks)"
elif [ -x "$HOME/.local/bin/gitleaks" ]; then
  GITLEAKS="$HOME/.local/bin/gitleaks"
else
  echo "🛑 gitleaks が見つからないのだ。秘密情報スキャンができないためコミットを中断するのだ。" >&2
  echo "   導入: https://github.com/gitleaks/gitleaks/releases から linux_x64 を ~/.local/bin に入れるのだ。" >&2
  echo "   （どうしても今回だけ通すなら git commit --no-verify ※非推奨）" >&2
  exit 1
fi

# repo ルートを解決し、allowlist 設定を明示的に渡す（cwd に依存させない）。
REPO_ROOT="$(git rev-parse --show-toplevel)"
# ステージ済み差分のみをスキャン（--staged）。秘密値はログに出さない（--redact）。
if ! "$GITLEAKS" git --staged --no-banner --redact -v -c "$REPO_ROOT/.gitleaks.toml" "$REPO_ROOT"; then
  echo "" >&2
  echo "🛑 秘密情報らしき文字列を検出したのだ。コミットを中断したのだ。" >&2
  echo "   上の検出箇所を確認し、鍵/アカウントIDはプレースホルダ <...> に直すのだ。" >&2
  echo "   誤検知なら .gitleaks.toml の allowlist に追記するのだ。" >&2
  exit 1
fi

echo "✅ gitleaks: 秘密情報なし。コミットを続行するのだ。"
exit 0
